# Common build outputs
*.o
*.a
*.so
*.ko
*.mod
*.mod.c
*.mod.o
*.d
.*.cmd
Module.symvers
modules.order


# Shared-object export helpers: keep only the hand-maintained inputs
so/**
!so/
!so/symbols.txt
!so/deflate_types.h

# macro_test_content: keep only the two markdown docs
macro_test_content/**
!macro_test_content/
!macro_test_content/Conclusion.md
!macro_test_content/Readme.md

# Ignore all pigz/upstream vendor trees for now
pigz_macro/**

# Ignore correctness test directory outputs and sources for now
test_zlib_lkm/**

# zlib_lkm: keep sources + Makefile + markdown only
zlib_lkm/**
!zlib_lkm/
!zlib_lkm/Makefile
!zlib_lkm/README.md
!zlib_lkm/*.c
!zlib_lkm/*.h
zlib_lkm/*.mod.c

# zlib_upstream_user: keep Makefile + markdown only
# (directory currently only contains build wrapper files, no local source copies)
zlib_upstream_user/**
!zlib_upstream_user/
!zlib_upstream_user/Makefile
!zlib_upstream_user/README.md
!zlib_upstream_user/*.c
!zlib_upstream_user/*.h

# zlib_upstream_user_trim: keep only necessary wrapper files
zlib_upstream_user_trim/**
!zlib_upstream_user_trim/
!zlib_upstream_user_trim/Makefile
!zlib_upstream_user_trim/README.md
!zlib_upstream_user_trim/exports.map
!zlib_upstream_user_trim/*.c
!zlib_upstream_user_trim/*.h

# zlib_user: keep local source copy + Makefile + markdown
zlib_user/**
!zlib_user/
!zlib_user/Makefile
!zlib_user/README.md
!zlib_user/*.c
!zlib_user/*.h
