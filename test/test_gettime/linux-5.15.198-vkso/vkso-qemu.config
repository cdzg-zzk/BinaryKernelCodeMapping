# Native x86-64 correctness scope
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_VKSO_TIME=y
CONFIG_SMP=y
CONFIG_MULTIUSER=y
CONFIG_FUTEX=y
CONFIG_NAMESPACES=y
CONFIG_TIME_NS=y
CONFIG_MODULES=y
CONFIG_NET=y
CONFIG_BLOCK=y
CONFIG_PCI=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_EXT4_FS=y
CONFIG_NUMA=y

# Counter backends are compiled even when the current QEMU mode cannot run all
# of them.
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_PARAVIRT_CLOCK=y
CONFIG_KVM_GUEST=y
CONFIG_ACPI=y
CONFIG_HYPERV=y

# Explicitly excluded compatibility/API families.
# CONFIG_IA32_EMULATION is not set
# CONFIG_X86_X32 is not set
# CONFIG_X86_SGX is not set
# CONFIG_CHECKPOINT_RESTORE is not set
