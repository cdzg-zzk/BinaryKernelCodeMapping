# Native x86-64 VKSO bare-metal experiment requirements.
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_KALLSYMS=y
CONFIG_PERF_EVENTS=y
CONFIG_NAMESPACES=y
CONFIG_TIME_NS=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_BLK_DEV_NVME=y
CONFIG_EXT4_FS=y
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_X86_INTEL_PSTATE=y
CONFIG_IA32_EMULATION=n
CONFIG_X86_X32=n
CONFIG_X86_VSYSCALL_EMULATION=n
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_INFO_BTF=n
CONFIG_KASAN=n
CONFIG_KCSAN=n
CONFIG_UBSAN=n
CONFIG_KCOV=n
CONFIG_GCOV_KERNEL=n
CONFIG_PROVE_LOCKING=n
CONFIG_LOCKDEP=n
CONFIG_FTRACE=n
CONFIG_FUNCTION_TRACER=n
CONFIG_WERROR=n
CONFIG_SYSTEM_TRUSTED_KEYS=""
CONFIG_SYSTEM_REVOCATION_KEYS=""
CONFIG_LOCALVERSION=""
CONFIG_LOCALVERSION_AUTO=n
