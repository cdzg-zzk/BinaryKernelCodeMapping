CONFIG_EMBEDDED=y
CONFIG_EXPERT=y

CONFIG_MODULES=y
# CONFIG_MODULE_UNLOAD is not set
# CONFIG_MODVERSIONS is not set
# CONFIG_MODULE_SIG is not set

CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y

CONFIG_PCI=y
CONFIG_ACPI=y
CONFIG_TTY=y
# CONFIG_VT is not set
# CONFIG_UNIX98_PTYS is not set
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
# CONFIG_SERIAL_8250_PNP is not set
# CONFIG_PNP is not set

CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y

CONFIG_PERF_EVENTS=y
CONFIG_HW_PERF_EVENTS=y

CONFIG_NR_CPUS=2
CONFIG_PREEMPT_NONE=y
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT is not set
# CONFIG_PREEMPT_DYNAMIC is not set
CONFIG_NO_HZ_IDLE=y
CONFIG_HZ_100=y
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set
# CONFIG_HZ_1000 is not set

# Keep the guest layout and runtime behavior stable across boots.
# CONFIG_RANDOMIZE_BASE is not set
# CONFIG_RANDOMIZE_MEMORY is not set
# CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT is not set

# Strip subsystems that do not participate in the crc32 micro benchmark.
# CONFIG_NET is not set
# CONFIG_INET is not set
# CONFIG_WIRELESS is not set
# CONFIG_BT is not set
# CONFIG_CFG80211 is not set
# CONFIG_MAC80211 is not set
# CONFIG_INPUT is not set
# CONFIG_SERIO is not set
# CONFIG_SOUND is not set
# CONFIG_HID is not set
# CONFIG_USB is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_EXT4_FS is not set
# CONFIG_BTRFS_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_FUSE_FS is not set
# CONFIG_9P_FS is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
# CONFIG_SCSI is not set
# CONFIG_ATA is not set
# CONFIG_NVME_CORE is not set
# CONFIG_VIRTIO_MENU is not set

# Remove instrumentation and heavyweight background machinery that adds
# noise without helping this microbenchmark.
# CONFIG_AUDIT is not set
# CONFIG_BPF is not set
# CONFIG_BPF_SYSCALL is not set
# CONFIG_CGROUPS is not set
# CONFIG_NAMESPACES is not set
# CONFIG_SECCOMP is not set
# CONFIG_KPROBES is not set
# CONFIG_FUNCTION_TRACER is not set
# CONFIG_STACK_TRACER is not set
# CONFIG_KGDB is not set
# CONFIG_KDB is not set
# CONFIG_MAGIC_SYSRQ is not set
# CONFIG_NMI_WATCHDOG is not set
# CONFIG_SOFTLOCKUP_DETECTOR is not set
# CONFIG_DETECT_HUNG_TASK is not set
# CONFIG_SCHED_AUTOGROUP is not set
# CONFIG_STACKPROTECTOR_STRONG is not set
# CONFIG_KASAN is not set
# CONFIG_KCSAN is not set
# CONFIG_UBSAN is not set
# CONFIG_KCOV is not set
# CONFIG_GCOV_KERNEL is not set
